# =====================================================================
# Ultra Personal Trainer - Variaveis de ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commitar .env.local
# =====================================================================

# --- Supabase (obrigatorio) ----------------------------------------------
# Obtidos em: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Chave de servidor - NUNCA exponha no frontend
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# --- App ---------------------------------------------------------------
# URL publica do app, usada em redirects de e-mail
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Asaas (pagamentos) ------------------------------------------------
# Sandbox: https://sandbox.asaas.com  |  Producao: https://www.asaas.com
ASAAS_API_KEY=$aact_hmlg_xxx
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_TOKEN=defina-um-token-secreto-aqui
